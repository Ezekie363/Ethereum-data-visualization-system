# 离线 CSV 下载模式当前无需配置 RPC。
# 可保留该文件用于后续扩展参数。

# ── 实时 API 模式（可选）──────────────────────────────────────────────────────
# Etherscan 免费 API Key，申请地址：https://etherscan.io/myapikey
# 不填写也可运行，但速率限制更严（约 1 次/5 秒），可能导致实时快照偶发失败。
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── RPC 实时模式（全量指标）────────────────────────────────────────────────────
# Alchemy 免费 RPC URL（注册后获取）
# 格式：https://eth-mainnet.g.alchemy.com/v2/<YOUR_KEY>
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_key_here

# 离线刷新服务端口（默认 5001）
# OFFLINE_API_PORT=5001
